<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.li.bbs.interaction.repository.FollowRelationRepository">

    <select id="existsByUserIdAndTargetUserId" resultType="boolean">
        SELECT COUNT(1) FROM follows WHERE user_id = #{userId} AND target_user_id = #{targetUserId}
    </select>

    <resultMap id="FollowRelationResultMap" type="com.li.bbs.interaction.domain.FollowRelation">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="target_user_id" property="targetUserId"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="findByTargetUserId" resultMap="FollowRelationResultMap">
        SELECT id, user_id, target_user_id, created_at FROM follows WHERE target_user_id = #{targetUserId}
    </select>

    <insert id="insert" parameterType="com.li.bbs.interaction.domain.FollowRelation" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO follows(user_id, target_user_id, created_at) VALUES(#{userId}, #{targetUserId}, NOW())
    </insert>

</mapper>

