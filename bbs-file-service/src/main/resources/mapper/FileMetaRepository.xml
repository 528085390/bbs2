<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.li.bbs.file.repository.FileMetaRepository">

    <resultMap id="FileMetaResultMap" type="com.li.bbs.file.domain.FileMeta">
        <id column="id" property="id"/>
        <result column="owner_type" property="ownerType"/>
        <result column="owner_id" property="ownerId"/>
        <result column="filename" property="filename"/>
        <result column="storage_path" property="storagePath"/>
        <result column="content_type" property="contentType"/>
        <result column="size" property="size"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="findById" resultMap="FileMetaResultMap">
        SELECT id, owner_type, owner_id, filename, storage_path, content_type, size, created_at
        FROM file_meta
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.li.bbs.file.domain.FileMeta" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO file_meta(owner_type, owner_id, filename, storage_path, content_type, size, created_at)
        VALUES(#{ownerType}, #{ownerId}, #{filename}, #{storagePath}, #{contentType}, #{size}, NOW())
    </insert>

    <delete id="deleteById">
        DELETE FROM file_meta WHERE id = #{id}
    </delete>

</mapper>

