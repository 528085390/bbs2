<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.li.bbs.notification.repository.NotificationRepository">

    <resultMap id="NotificationResultMap" type="com.li.bbs.notification.domain.Notification">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="type" property="type"/>
        <result column="payload" property="payload"/>
        <result column="is_read" property="read"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="findByUserIdOrderByCreatedAtDesc" resultMap="NotificationResultMap">
        SELECT id, user_id, type, payload, is_read, created_at
        FROM notifications
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
    </select>

    <select id="findAllByOrderByCreatedAtDesc" resultMap="NotificationResultMap">
        SELECT id, user_id, type, payload, is_read, created_at
        FROM notifications
        ORDER BY created_at DESC
    </select>

    <insert id="insert" parameterType="com.li.bbs.notification.domain.Notification" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO notifications(user_id, type, payload, is_read, created_at)
        VALUES(#{userId}, #{type}, #{payload}, #{read}, NOW())
    </insert>

</mapper>

